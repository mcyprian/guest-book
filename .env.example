# Database (used by Docker Compose)
DB_PASSWORD=guestbook

# Auth — JWT secret (generate a random string for production)
JWT_SECRET=change-me-to-a-random-secret
JWT_LIFETIME_SECONDS=3600

# First user credentials (seeded on first startup)
FIRST_USER_EMAIL=admin@example.com
FIRST_USER_PASSWORD=changeme

# CORS — allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
